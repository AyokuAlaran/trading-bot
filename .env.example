# Polymarket Trading Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env   (Mac/Linux)
#                     copy .env.example .env  (Windows)
# 2. Fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────

# ── Required: Claude API (analytical bot) ────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Required: Supabase (all trade storage) ────────────────────────────
# Find these in your Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Market source ─────────────────────────────────────────────────────
# true  → fetch live markets from Polymarket Gamma API
# false → use mock_markets.json (default, works offline)
USE_LIVE_MARKETS=false

# ── Sniper bot: news sources ───────────────────────────────────────────
# The sniper uses free RSS feeds by default (no key needed).
# Optional: NewsAPI for higher-volume, lower-latency headlines.
# Get a free key at: https://newsapi.org
NEWSAPI_KEY=

# ── Analytical bot scheduling ─────────────────────────────────────────
# How often the analytical bot runs a full analysis cycle
ANALYTICAL_BOT_INTERVAL_MINUTES=30

# ── Sniper bot polling ────────────────────────────────────────────────
# How often the sniper checks for new confirmed match outcomes
SNIPER_POLL_INTERVAL_SECONDS=15

# ── Position sizing ───────────────────────────────────────────────────
# Max fraction of bankroll per trade (hard cap)
ANALYTICAL_MAX_BET_PCT=0.05   # 5%  — analytical uses 25% Kelly
SNIPER_MAX_BET_PCT=0.20       # 20% — sniper uses 50% Kelly
